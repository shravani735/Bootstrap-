                    <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Day</th>
                        <th>Subject</th>
                        <th>Duration</th>
                        <th>Allocated Teacher</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>02-04-2026</td>
                        <td>9:00 AM</td>
                        <td>monday</td>
                        <td>java</td>
                        <td>2 hours</td>
                        <td>miss.sayli </td>
                    </tr>
                    <tr class="table-info">
                        <td>02-04-2026</td>
                        <td>10:00 AM</td>
                        <td>monday</td>                       
                         <td>python</td>
                        <td>2 hours</td>
                        <td>miss.priya</td>
                    </tr>
                    <tr class="table-warning">
                        <td>02-04-2026</td>
                        <td>11:00 AM</td>
                        <td>monday</td>
                        <td>JavaScript</td>
                        <td>2 hours</td>
                        <td>miss.sneha</td>
                    </tr>
                    <tr class="table-success">
                        <td>02-04-2026</td>
                        <td>12:00 PM</td>
                        <td>monday</td>
                        <td>css</td>
                        <td>2 hours</td>
                        <td>mr.vikrant</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</body>

</html>